classDiagram
    class SessionFlow~TState~ {
      +CurrentState : TState
      +IsInitialized : bool
      +Register(state, onEnter, onTick, onExit)
      +TransitionTo(state)
      +Tick()
    }

    class IAudioService {
      <<interface>>
      +PlayUiClick()
      +PlayKick()
      +PlayWhistle()
      +PlayBallBlock()
      +PlayGoalScored()
      +StartAmbientCrowd()
      +StopAmbientCrowd()
      +StartMenuMusic()
      +PauseMenuMusic()
    }

    class ISettingsService {
      <<interface>>
      +GameSpeedMultiplier : float
      +MotionInputEnabled : bool
      +HandsOnlyMode : bool
    }

    class GlobalAudioServiceAdapter {
      +PlayUiClick()
      +PlayKick()
      +PlayWhistle()
      +PlayBallBlock()
      +PlayGoalScored()
      +StartAmbientCrowd()
      +StopAmbientCrowd()
    }

    class GameSettingsServiceAdapter {
      +GameSpeedMultiplier : float
      +MotionInputEnabled : bool
      +HandsOnlyMode : bool
    }

    class GlobalGameAudio {
      +Instance
      +SetSfxVolume(volume)
      +SetCrowdVolume(volume)
      +SetMusicVolume(volume)
      +PlayUiClick()
      +PlayKick()
    }

    class GameSettings {
      +Instance
      +gameSpeedMultiplier : float
      +motionInputEnabled : bool
      +handsOnlyMode : bool
    }

    GlobalAudioServiceAdapter ..|> IAudioService
    GameSettingsServiceAdapter ..|> ISettingsService
    GlobalAudioServiceAdapter --> GlobalGameAudio : delegates to singleton
    GameSettingsServiceAdapter --> GameSettings : reads singleton
    SessionFlow~TState~ <.. FreekickController : lifecycle orchestration
    SessionFlow~TState~ <.. GoalkeeperGameManager : lifecycle orchestration
    SessionFlow~TState~ <.. PenaltyController : lifecycle orchestration
    SessionFlow~TState~ <.. ObstacleCourseGameManager : lifecycle orchestration
